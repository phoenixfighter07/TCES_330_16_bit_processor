-- Quartus Prime generated Memory Initialization File (.mif)

WIDTH=16;
DEPTH=256;

ADDRESS_RADIX=HEX;
DATA_RADIX=HEX;

CONTENT BEGIN
	[000..01A]  :   0000;
	01B  :   21BA;
	[01C..029]  :   0000;
	02A  :   A04E;
	[02B..03B]  :   0000;
	03C  :   71AC;
	[03D..07D]  :   0000;
	07E  :   B17F;
	[07F..0FF]  :   0000;
END;
